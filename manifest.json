{
  "manifest_version": 2,
  "name": "Notepad",
  "version": "1.0",
  "description": "This is a basic Firefox extension.",
  "icons": {
    "48": "logo.png"
  },
  "permissions": ["activeTab", "storage"],
  "browser_action": {
    "default_title": "Notepad",
    "default_icon": "logo.png",
    "default_popup": "index.html"
  }
}
